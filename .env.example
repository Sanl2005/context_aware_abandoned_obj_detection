# Environment Configuration for SentinelEye

## Service Endpoints

# ML Service (Flask)
ML_SERVICE_URL=http://127.0.0.1:5000
VIDEO_FEED_ENDPOINT=/video_feed

# Rails Backend
RAILS_API_URL=http://127.0.0.1:3000/api

# Frontend
FRONTEND_URL=http://localhost:3001

## Object Detection Settings

# Camera Configuration
CAMERA_SOURCE=0  # 0 for default webcam, or path to video file

# Detection Settings
YOLO_MODEL=yolov8n.pt  # nano model (fastest)
# Alternative models: yolov8s.pt (small), yolov8m.pt (medium), yolov8l.pt (large)

# Tracking Settings
ABANDONED_THRESHOLD_SECONDS=5  # Time before marking object as abandoned
CONFIDENCE_THRESHOLD=0.5  # Minimum confidence to display detection

# Tracked Object Classes
TRACKED_CLASSES=person,handbag,backpack,suitcase,cell phone,teddy bear,chair,tv,remote,keyboard,mouse,book,laptop,bottle

## Performance Settings

# Video Settings
MAX_FPS=30  # Maximum frames per second
VIDEO_QUALITY=85  # JPEG quality (0-100)

# Processing Settings
ENABLE_GPU=false  # Set to true if CUDA is available
BATCH_SIZE=1  # Number of frames to process at once

## UI Settings

# Theme
THEME=dark  # dark or light
PRIMARY_COLOR=#3b82f6
ACCENT_COLOR=#ef4444
SUCCESS_COLOR=#22c55e

# Layout
VIDEO_ASPECT_RATIO=16:9
SHOW_CONFIDENCE_SCORES=true
SHOW_FPS=false

## Alerts & Notifications

# Alert Settings
ENABLE_SOUND_ALERTS=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false

# Email Configuration (if enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=security@example.com

## Database Settings (Rails)

# Development
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=sentineleye_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=password

## Security

# CORS Settings
CORS_ENABLED=true
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# API Keys (if needed)
API_KEY=your-api-key-here
SECRET_KEY=your-secret-key-here

## Logging

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
LOG_FILE=logs/sentineleye.log
ENABLE_CONSOLE_LOGGING=true

## Advanced Settings

# Object Tracking
IOU_THRESHOLD=0.3  # Intersection over Union threshold for tracking
MAX_DISAPPEARED_FRAMES=30  # Frames before removing lost object

# Performance Optimization
ENABLE_FRAME_SKIP=false  # Skip frames to improve performance
FRAME_SKIP_RATE=2  # Process every Nth frame if enabled

# Save Recordings
SAVE_DETECTIONS=false
RECORDINGS_PATH=./recordings
SAVE_FORMAT=mp4

## Notes

# - This file is a template. Copy to .env for use
# - Update values according to your setup
# - Keep sensitive information secure
# - Restart services after changing configuration
