# Google OAuth Configuration
# Get your Client ID from: https://console.cloud.google.com/apis/credentials
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Apple OAuth Configuration  
# Get your credentials from: https://developer.apple.com/account/resources/identifiers/list/serviceId
REACT_APP_APPLE_CLIENT_ID=com.yourapp.service
REACT_APP_APPLE_REDIRECT_URI=http://localhost:3000

# API Configuration
REACT_APP_API_URL=http://127.0.0.1:3001
